{
  "name": "expoapp",
  "main": "expo-router/entry",
  "version": "0.63.1",
  "type": "module",
  "scripts": {
    "start": "npm run check-redis && npx expo start",
    "check-redis": "grep -q \"REDIS_URL=\" .env.local || (echo \"!!!ERROR!!! Redis is required. Please see 'expoapp/README.md' for instructions.\" && exit 1)",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "npx expo start --web",
    "build": "npx startupjs build",
    "start-production": "npx startupjs start-production",
    "test-worker": "SKIP_SERVER_INIT_SIDE_EFFECTS=true ENABLE_WORKER_INTEGRATION_PLUGIN=true NODE_OPTIONS='--experimental-detect-module --import=startupjs/nodeRegister' mocha ./server/tests/worker.integration.js --timeout 120000",
    "test-worker-separate": "SKIP_SERVER_INIT_SIDE_EFFECTS=true ENABLE_WORKER_INTEGRATION_PLUGIN=true WORKER_TEST_USE_SEPARATE_PROCESS=true NODE_OPTIONS='--experimental-detect-module --import=startupjs/nodeRegister' mocha ./server/tests/worker.integration.js --timeout 120000",
    "test": "jest --watchAll",
    "startupjs:help": "npx startupjs --help",
    "worker": "npx startupjs start-worker"
  },
  "jest": {
    "preset": "jest-expo"
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.0",
    "@expo/vector-icons": "^15.0.3",
    "@fortawesome/free-solid-svg-icons": "^5.12.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.3",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/native": "^7.1.6",
    "@startupjs-ui/mdx": "^0.3.0",
    "@startupjs/router": "^0.63.1",
    "@startupjs/worker": "^0.63.1",
    "expo": "~55.0.11",
    "expo-clipboard": "~55.0.11",
    "expo-document-picker": "~55.0.11",
    "expo-font": "~55.0.6",
    "expo-image-picker": "~55.0.16",
    "expo-linking": "~55.0.11",
    "expo-router": "~55.0.10",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-system-ui": "~55.0.13",
    "expo-web-browser": "~55.0.12",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.4",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-pager-view": "8.0.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.7.2",
    "startupjs": "^0.63.1",
    "startupjs-ui": "^0.3.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@types/react": "~19.2.10",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~55.0.13",
    "mocha": "^11.0.1",
    "react-test-renderer": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": [
      "eslint --fix"
    ]
  }
}
